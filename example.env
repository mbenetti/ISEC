# Default Operation Costs
# Adjust these values to change the default costs for edit operations
DEFAULT_SUBSTITUTION_COST=1.1
DEFAULT_INSERTION_COST=1.3
DEFAULT_DELETION_COST=1.3
DEFAULT_TRANSPOSITION_COST=0.5

# Operation Cost Factor
# Scaling factor for total operation cost penalty (k in: average_cost + k*total_cost)
COST_FACTOR_PENALIZATION=0.2

# # File Paths
# Path to the custom costs Excel file
CUSTOM_COSTS_FILE=Costo_Personalizado.xlsx

# Path to the sentences Excel file
# SENTENCES_FILE=Clases.xlsx
SENTENCES_FILE=Sentences.xlsx
# SENTENCES_FILE=Tabla3.xlsx
# SENTENCES_FILE=provincias.xlsx
# SENTENCES_FILE=provincias_small.xlsx

# Column Names for Sentences File
SENTENCES_NAME_COLUMN=Name
SENTENCES_FREQUENCY_COLUMN=Frequency
SENTENCE_GROUP=Group
SENTENCE_SUBGROUP=Subgroup

# Same group exclusion flag
# If set to True, sentences from the same group will be excluded from matching
SAME_GROUP_EXCLUSION=True
SAME_SUBGROUP_EXCLUSION=True

# ISEC Frequency Scaling Configuration
# Enable logarithmic scaling of frequencies to reduce their impact
ISEC_FREQUENCY_SCALING_ENABLED=True
# Logarithm base for frequency scaling (e.g., 10 for log10, 2 for log2, e for natural log)
ISEC_FREQUENCY_LOG_BASE=10


# Column Names for Custom Costs File
COSTS_CHAR1_COLUMN=Character1
COSTS_CHAR2_COLUMN=Character2
COSTS_COST_COLUMN=Cost
COSTS_OPERATION_COLUMN=Operation

# ISEC Weight Configuration
# Weight for semantic distance (0.0-1.0)
# Morphologic weight = 1.0 - semantic_weight
ISEC_SEMANTIC_WEIGHT=0.2

# Number of top semantic matches to compare
# The algorithm will find the top k closest semantic matches and calculate
# cost distances for each, then average them for the final ISEC score
ISEC_TOP_K_MATCHES=1
# Output Excel filename
ISEC_OUTPUT_FILE=ISEC_Results.xlsx
# Ollama Configuration for Semantic Distance
# URL for Ollama API service
OLLAMA_HOST=http://localhost:11434
# Embedding model to use
OLLAMA_EMBEDDING_MODEL=embeddinggemma
